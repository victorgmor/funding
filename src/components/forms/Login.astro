                  type="password"
                />
              </div>
              <div class="flex items-center justify-between py-2">
                <div class="flex items-center">
                  <input
                    class="w-4 h-4 text-black bg-black rounded-full border-zinc-500 focus:ring-white focus:border-white"
                    type="checkbox"
                    id="remember-me"
                    name="remember-me"
                  />
                  <label
                    class="block ml-2 text-xs text-white uppercase font-display tracking-wide"
                    for="remember-me">Remember me</label
                  >
                </div><div class="text-xs">
                  <a class="text-white hover:text-zinc-500" href="/forms/forgot"
