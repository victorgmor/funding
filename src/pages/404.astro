---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const items = [
  {
    title: "Funds",
    description: "Browse managed Polymarket funds.",
    link: "/",
  },
  {
    title: "Leaderboard",
    description: "See top managers by performance.",
    link: "/leaderboard",
  },
  {
    title: "Docs",
    description: "How deposits, trading, and settlement work.",
    link: "/docs",
  },
];
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <Text
        tag="h1"
        variant="display3XL"
        class="text-primary font-semibold tracking-tighter text-balance"
      >
        404 — Page not found
      </Text>
      <Text
        tag="p"
        variant="textBase"
        class="text-primary/60 mt-4 text-balance"
      >
        That URL isn’t part of PolyFund. Try one of these:
      </Text>
      <ul class="text-primary/70 mt-8 space-y-4 text-base">
        {
          items.map((item) => (
            <li>
              <a href={item.link} class="text-primary font-medium hover:underline">
                {item.title}
              </a>
              <span class="text-primary/50"> — {item.description}</span>
            </li>
          ))
        }
      </ul>
      <div class="mt-8 flex">
        <Button isLink size="xs" variant="accent" href="/" class="w-auto">
          Go home
        </Button>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
