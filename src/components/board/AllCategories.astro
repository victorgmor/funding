---
import { categories } from "@/data/categories.json";
import Filters from "./Filters.astro";
---

<section>
  <div
    class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
    <div class="border-t border-zinc-800 pt-2">
      <div class="flex flex-col gap-8 lg:gap-0">
        <p class="text-white text-base tracking-wide font-display uppercase">
          Find the job that suits your lifestyle
        </p>
        <p
          class="text-base uppercase md:text-3xl mt-32 lg:text-6xl font-display tracking-tight text-white">
          Discover a wide range of thrilling job opportunities that align with
          your interests and chosen field of study.
        </p>
        <div class="mt-12 w-full col-span-full">
          <div
            class="grid grid-cols-1 md:grid-cols-3 gap-4 w-full py-4 border-b border-zinc-800">
            <div>
              <div class="flex justify-start items-center relative">
                <input
                  class="bg-transparent placeholder-white block w-full h-10 text-xs border-0 pl-0 pr-10 text-white focus:ring-0 focus:border-b focus:border-white focus:ring-white"
                  type="text"
                  placeholder="Job, Category, Keyboard,..."
                />
              </div>
            </div>
            <div>
              <div class="flex rounded-md items-center">
                <select
                  id="location"
                  name="location"
                  class="block w-full h-10 text-xs bg-transparent border-0 pl-0 pr-10 text-white focus:ring-0 focus:border-b focus:border-white focus:ring-white">
                  <option selected>Choose a country</option>
                  <option>United States</option>
                  <option>Mexico</option>
                </select>
              </div>
            </div>
            <div>
              <button
                class="flex items-center border border-white text-xs rounded-full w-full h-10 px-4 py-2 uppercase font-display text-white transition-all bg-black hover: hover:text-black duration-200 focus:ring-2 focus:ring-white focus:ring-offset-black focus:ring-offset-4 justify-between"
                role="search"
                >Search
                <span>&rarr;</span></button
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section>
  <div
    class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
    <div class="border-t border-zinc-800 pt-2">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <Filters />

        <div class="flex flex-col gap-8 lg:gap-0 lg:col-span-2">
          <p class="text-white text-base tracking-wide font-display uppercase">
            Explore all our categories
          </p>
          <div>
            <p
              class="text-base uppercase md:text-3xl mt-32 lg:text-6xl font-display tracking-tight text-white">
              Discover a wide range of thrilling job opportunities that align
              with your interests and chosen field of study.
            </p>
          </div>
          <ul
            class="flex flex-col mt-12 col-span-full divide-y border-y divide-zinc-800 border-zinc-800"
            role="list">
            {
              categories.map((template) => (
                <>
                  <li class="w-full py-2">
                    <a
                      href={template.url}
                      title={template.title}
                      class="grid grid-cols-1 md:grid-cols-2 w-full lg:grid-cols-3 text-white hover:text-zinc-500 duration-200">
                      <p class="tracking-wide text-base font-display ">
                        {template.title}
                      </p>

                      <p class=" text-base tracking-tight ">
                        <span class="font-mono">{template.applicants}</span>
                        Applicants
                      </p>
                      <span class="font-display text-right"> &rarr;</span>
                    </a>
                  </li>
                </>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
