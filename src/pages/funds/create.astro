---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BackLink from "@/components/fundations/elements/BackLink.astro";
import CreateFundForm from "@/components/funds/CreateFundForm";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <Wrapper variant="narrow">
        <BackLink />
        <Text tag="h1" variant="displaySM" class="text-primary mt-6 font-semibold">
          Create fund
        </Text>
        <p class="text-primary/60 mt-2 text-sm">
          Launch a managed pool. Investors commit capital from their deposit wallets;
          you trade with proportional fan-out.
        </p>

        <CreateFundForm client:load />
      </Wrapper>
    </Wrapper>
  </section>
</BaseLayout>
