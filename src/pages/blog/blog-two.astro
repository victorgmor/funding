---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import EntriesTwo from "@/components/entries/EntriesTwo.astro";
const allPosts = await getCollection("posts");
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
---

<BaseLayout>
  <section>
    <div
      class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
      <div class="border-t border-zinc-800 pt-2">
        <div class="flex flex-col gap-8 lg:gap-0">
          <p class="text-white text-base tracking-wide font-display uppercase">
            Welcome to our blog
          </p>
          <p
            class="text-base uppercase md:text-3xl mt-32 lg:text-6xl font-display tracking-tight text-white">
            Exploring the world of work ⏤ insights, tips, and career stories
          </p>
          <div class="mt-6 flex gap-x-2 border-b border-zinc-800 pb-2">
            <label for="email-address" class="sr-only">Email address</label>
            <input
              id="email-address"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="bg-transparent placeholder-white block w-full h-10 text-xs border-0 pl-0 pr-10 text-white focus:ring-0 focus:border-b focus:border-white focus:ring-white"
              placeholder="Enter your email"
            />
            <button
              type="submit"
              class="flex items-center border border-white text-xs rounded-full w-full h-10 px-4 py-2 uppercase font-display text-white transition-all bg-black hover:bg-white hover:text-black duration-200 focus:ring-2 focus:ring-white focus:ring-offset-black focus:ring-offset-4 justify-between"
              >subscribe
              <span>&rarr;</span></button
            >
          </div>
          <ol
            role="list"
            class="flex flex-wrap gap-3 mt-32 font-display uppercase tracking-wide text-white text-xs">
            {
              tags.map((tag) => (
                <li class="inline-flex items-center ">
                  <a
                    class="hover:text-zinc-500 duration-200"
                    href={`/tags/${tag}`}>
                    {tag}
                  </a>
                </li>
              ))
            }
          </ol>
        </div>
      </div>

      <ul class="grid grid-cols-1 mt-2 lg:grid-cols-1 lg:gap-y-32 pt-2">
        {
          allPosts
            .slice()
            .map((post) => (
              <EntriesTwo
                url={"/posts/" + post.slug}
                title={post.data.title}
                description={post.data.description}
                alt={post.data.title}
                pubDate={post.data.pubDate.toString().slice(0, 10)}
                author={post.data.author}
                image={post.data.image.url}
              />
            ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
