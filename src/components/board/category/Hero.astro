<section>
  <div
    class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
    <div class="border-t border-zinc-300 pt-2">
      <div class="flex flex-col gap-8 lg:gap-0">
        <p class="text-base font-medium text-black uppercase font-display">
          Kickstart your career in development with exciting entry-level
          opportunities
        </p>
        <h1
          class="text-base md:text-3xl mt-32 lg:text-6xl font-display uppercase text-black text-balance">
          Junior dev entry job board
        </h1>
        <div class="mt-12 w-full col-span-full">
          <div
            class="grid grid-cols-1 md:grid-cols-2 gap-4 w-full py-4 border-b border-zinc-300">
            <div class="flex justify-start items-center relative">
              <input
                class="block w-full text-xs bg-transparent border-0 pl-0 pr-10 h-12 text-black focus:ring-2 focus:border-b focus:border-zinc-300 focus:ring-black"
                type="text"
                placeholder="Search"
                aria-label="Search"
                aria-describedby="searchIcon"
              />
              <svg
                id="searchIcon"
                class="absolute right-3 z-10 cursor-pointer"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                role="img"
                aria-label="Search Icon">
                <title>Search Icon</title>
                <path
                  d="M10 17C13.866 17 17 13.866 17 10C17 6.13401 13.866 3 10 3C6.13401 3 3 6.13401 3 10C3 13.866 6.13401 17 10 17Z"
                  stroke="#6b7280"
                  stroke-width="1.66667"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
                <path
                  d="M21 21L15 15"
                  stroke="#6b7280"
                  stroke-width="1.66667"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </div>

            <div>
              <div class="flex rounded-md items-center">
                <select
                  id="location"
                  name="location"
                  class="block w-full text-xs bg-transparent border-0 pl-0 pr-10 h-12 text-black focus:ring-2 focus:border-b focus:border-zinc-300 focus:ring-black">
                  <option selected>Category</option>
                  <option>UI/UX</option>
                  <option>Web Development</option>
                  <option>Mobile Development</option>
                  <option>Full Stack Development</option>
                  <option>Data Science</option>
                  <option>DevOps</option>
                  <option>Blockchain</option>
                  <option>AI</option>
                </select>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
