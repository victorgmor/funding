---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";

// Componetes
import JobEntry from "@/components/jobs/JobEntry.astro";
// Content
import { getCollection } from "astro:content";
const allJobs = await getCollection("jobs");
allJobs.sort(
  (a, b) =>
    new Date(b.data.datePosted).getTime() -
    new Date(a.data.datePosted).getTime(),
);
const categories = [...new Set(allJobs.map((job) => job.data.category))];
---

<div>
  <Text
    tag="h1"
    variant="textBase"
    class="font-medium tracking-tight text-primary text-balance"
    >Categories
  </Text>
  <div class="flex flex-col mt-1 border-t border-primary/10 gap-8">
    {
      categories.map((category) => {
        const jobsInCategory = allJobs.filter(
          (job) => job.data.category === category,
        );
        return (
          <article id={category} class="py-2">
            <Text
              tag="h2"
              variant="textBase"
              class="font-medium capitalize text-primary">
              {category}
            </Text>
            <div class="flex flex-col mt-1 divide-primary/10 border-primary/10 divide-y border-y">
              {jobsInCategory.slice(0, 4).map((post) => (
                <JobEntry post={post} />
              ))}
            </div>
          </article>
        );
      })
    }
  </div>
</div>
