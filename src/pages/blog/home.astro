---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import EntriesOne from "@/components/blog/EntriesOne.astro";
const allPosts = await getCollection("posts");
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
---

<BaseLayout>
  <section>
    <div
      class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
      <div class="border-t border-zinc-300 pt-2">
        <div class="flex flex-col gap-8 lg:gap-0">
          <p class="text-base font-medium text-black uppercase font-display">
            Welcome to our blog
          </p>
          <p
            class="text-base md:text-3xl mt-32 lg:text-6xl font-display uppercase text-black text-balance">
            Exploring the world of work ⏤ insights, tips, and career stories
          </p>
          <div class="mt-6 flex gap-x-2 border-b border-zinc-300 pb-2">
            <label
              for="email-address"
              class="sr-only"
              >Email address</label
            >
            <input
              id="email-address"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="block w-full text-xs bg-transparent border-0 pl-0 pr-10 h-12 text-black focus:ring-2 focus:border-b focus:border-zinc-300 focus:ring-black"
              placeholder="Enter your email"
            />
            <button
              type="submit"
              class="flex items-center ring-2 ring-black text-xs rounded-full w-full h-10 px-4 py-2 uppercase text-black transition-all bg-white hover:bg-black duration-500 focus:ring-2 hover:text-white focus:ring-black focus:ring-offset-white focus:ring-offset-2 justify-between"
              >subscribe
              <span>&rarr;</span></button
            >
          </div>
          <ol
            role="list"
            class="flex flex-wrap gap-3 mt-32 font-display uppercase tracking-wide text-white text-xs">
            {
              tags.map((tag) => (
                <li class="inline-flex items-center ">
                  <a
                    class="hover:text-zinc-500 duration-200"
                    href={`/blog/tags/${tag}`}>
                    {tag}
                  </a>
                </li>
              ))
            }
          </ol>
        </div>
      </div>

      <ul
        class="grid grid-cols-1 mt-2 lg:grid-cols-3 sm:grid-cols-2 gap-x-2 gap-y-24 border-t border-zinc-300 pt-2">
        {
          allPosts.slice().map((post) => (
            <EntriesOne
              url={"/blog/posts/" + post.slug}
              title={post.data.title}
              description={post.data.description}
              alt={post.data.title}
              pubDate={post.data.pubDate.toString().slice(0, 10)}
              author={post.data.author}
              image={post.data.image.url}
            />
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
