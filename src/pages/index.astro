---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Hero from "@/components/landing/Hero.astro";
import TopCreatorsCarousel from "@/components/landing/TopCreatorsCarousel";
import FundListPanel from "@/components/funds/FundListPanel";
import { getTopCreators } from "@/lib/funds/creators";
import { computeFundPoolPerformance } from "@/lib/funds/performance";
import { getAllFunds } from "@/lib/funds/store";

const funds = await getAllFunds();
const profitByFundSlug = Object.fromEntries(
  await Promise.all(
    funds.map(async (fund) => {
      const performance = await computeFundPoolPerformance(fund);
      return [fund.slug, performance?.profitUsdc ?? 0] as const;
    }),
  ),
);
const topCreators = getTopCreators(funds, { profitByFundSlug });
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <Hero />
      {
        topCreators.length > 0 && (
          <div class="mt-10">
            <TopCreatorsCarousel client:visible creators={topCreators} />
          </div>
        )
      }
      <div class="mt-8">
        <FundListPanel client:load funds={funds} />
      </div>
    </Wrapper>
  </section>
</BaseLayout>
