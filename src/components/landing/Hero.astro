---
import Text from "@/components/fundations/elements/Text.astro";
import { walletNavRadius } from "@/lib/walletNavChrome";
---

<div>
  <Text
    tag="h1"
    variant="display3XL"
    class="text-primary font-semibold tracking-tighter text-balance"
  >
    Get funding.<br />Back the best edge.
  </Text>
  <p class="text-primary/60 mt-4 max-w-2xl text-sm">
    Creators run discretionary pools. Investors commit capital from their deposit
    wallets; managers trade with proportional fan-out. Non-custodial on Polygon.
  </p>
  <div class="mt-6">
    <a
      href="/funds/create"
      class:list={[
        "bg-accent text-secondary hover:opacity-90 inline-flex w-fit items-center justify-center px-4 py-2 text-sm font-medium transition-opacity",
        walletNavRadius,
      ]}
    >
      Create fund
    </a>
  </div>
</div>
