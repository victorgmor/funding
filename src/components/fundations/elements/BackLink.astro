---
import ArrowLeft from "phosphor-astro/ArrowLeftBold.astro";

type Props = {
  href?: string;
  label?: string;
};

const { href = "/", label = "All funds" } = Astro.props;
---

<a
  href={href}
  class="group text-primary/70 hover:text-primary inline-flex items-center gap-2.5 text-sm font-medium transition-colors"
>
  <span
    class="border-primary/15 bg-primary/5 group-hover:border-primary/30 group-hover:bg-primary/10 flex size-7 items-center justify-center rounded-full border transition-colors"
  >
    <ArrowLeft
      class="size-3.5 transition-transform duration-200 group-hover:-translate-x-0.5"
    />
  </span>
  {label}
</a>
