# Polymarket Builder — https://polymarket.com/settings?tab=builder
# API key trio authenticates relayer requests (server-only).
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_PASSPHRASE=

# bytes32 builder code on your profile — attached to orders for fee attribution.
# Copy from Builder settings (not the same as the API key).
PUBLIC_POLY_BUILDER_CODE=

# DynamoDB (required). Point at your AWS tables for local dev and production.
FUNDS_TABLE=carriera-funds
CHALLENGES_TABLE=carriera-challenges
ENTITLEMENTS_TABLE=carriera-entitlements
MANDATES_TABLE=carriera-mandates
AWS_REGION=eu-west-1

# TRADING_SESSION_SECRET=  # encrypts stored CLOB sessions (defaults to POLY_BUILDER_API_SECRET in dev)

# SITE_URL=https://your-service.eu-west-1.on.aws

# Wallet that receives the 10% platform fee on paid fund unlocks.
# PLATFORM_FEE_WALLET=0xYourWalletAddress
