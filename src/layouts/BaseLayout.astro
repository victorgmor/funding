---
// Foundations
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
// Components
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/Navigation.astro";
import AppProviders from "@/components/app/AppProviders";

const {
  pageTitle = "PolyFund",
  description = "Copy-trade Polymarket managers through pooled funds.",
} = Astro.props;
---
<html
  lang="en"
  class="scroll-smooth"
>
  <head>
    <BaseHead title={pageTitle} description={description} />
    <script is:inline>
      try {
        const raw = localStorage.getItem("carriera:wallet-session");
        if (raw) document.documentElement.dataset.walletSession = "1";
      } catch {}
    </script>
    <style is:inline>
      /* One nav chip: swap the label, never swap the button. */
      [data-wallet-label-session] { display: none; }
      html[data-wallet-session="1"] [data-wallet-label-anon] { display: none; }
      html[data-wallet-session="1"] [data-wallet-label-session] { display: inline; }
      html[data-wallet-session="1"] [data-wallet-login] { pointer-events: none; }

      /* Panel connect CTAs: hide while a saved session is restoring. */
      [data-wallet-restoring] { display: none; }
      html[data-wallet-session="1"] [data-wallet-connect-cta] { display: none !important; }
      html[data-wallet-session="1"] [data-wallet-restoring] { display: block; }
    </style>
  </head>
  <body class="flex flex-col bg-secondary  min-h-svh">
    <AppProviders client:idle />
    <Navigation />
    <main class="grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
