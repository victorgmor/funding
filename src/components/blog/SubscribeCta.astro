---
// Fundations
import Button from "@/components/fundations/elements/Button.astro";
import Text from "@/components/fundations/elements/Text.astro";
---

<div>
  <Text
    tag="h3"
    variant="textBase"
    class="text-primary flex items-center gap-1 font-medium capitalize"
  >
    Subscribe to our newsletter
  </Text>
  <Text tag="p" variant="textSM" class="text-primary/60 mt-2">
    Enjoy the latest news and updates from our team and community.
  </Text>
  <form action="#" method="POST" class="mt-2">
    <div>
      <label for="email" class="text-primary block text-sm font-medium">
        Subscribe to our newsletter
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="border-primary/10 focus:border-primary text-primary w-full border-0 border-b bg-transparent px-0 text-xs focus:ring-0 focus:outline-none"
      />
    </div>
    <div class="mt-2 flex">
      <Button size="xs" variant="default" type="submit"> Subscribe </Button>
    </div>
  </form>
  <Text tag="p" variant="textXS" class="text-primary/60 mt-2">
    No spam, promise......
  </Text>
</div>
