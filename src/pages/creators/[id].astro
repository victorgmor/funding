---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BackLink from "@/components/fundations/elements/BackLink.astro";
import SealCheck from "@/components/fundations/icons/SealCheck.astro";
import CreatorFundList from "@/components/funds/CreatorFundList";
import CreatorAvatar from "@/components/creators/CreatorAvatar";
import CreatorName from "@/components/creators/CreatorName";
import CreatorLocalBio from "@/components/creators/CreatorLocalBio";
import CreatorWalletChip from "@/components/creators/CreatorWalletChip";
import { getFundsByCreator, getManagerProfile } from "@/lib/funds/store";
import { isCreatorWallet } from "@/lib/funds/creator";
import { sumCreatorProfit } from "@/lib/funds/creators";
import {
  computeFundPoolPerformance,
  type PoolTotalEntry,
} from "@/lib/funds/performance";
import { formatPercent, formatUsd } from "@/lib/funds/format";
import { managerDisplayName } from "@/lib/funds/managers-dynamodb";

const creatorId = Astro.params.id;
if (!creatorId) {
  return Astro.redirect("/404");
}

const funds = await getFundsByCreator(creatorId);
const walletId = isCreatorWallet(creatorId) ? creatorId : null;

if (funds.length === 0 && !walletId) {
  return Astro.redirect("/404");
}

const manager = funds[0]?.manager;
let name = manager?.name ?? "";
let verified = manager?.verified ?? false;
let profileImage: string | null = null;
const profileWalletId =
  walletId ?? (manager && isCreatorWallet(manager.id) ? manager.id : null);

if (profileWalletId) {
  const profile = await getManagerProfile(profileWalletId);
  name = managerDisplayName(profile);
  verified = profile.verified;
  profileImage = profile.avatarUrl;
}

const initial = name.trim().charAt(0).toUpperCase() || "?";

const performanceEntries = await Promise.all(
  funds.map(async (fund) => [
    fund.slug,
    await computeFundPoolPerformance(fund),
  ] as const),
);
const profitByFundSlug = Object.fromEntries(
  performanceEntries.map(([slug, performance]) => [
    slug,
    performance?.profitUsdc ?? 0,
  ]),
);

const initialPoolTotals: Record<string, PoolTotalEntry> = Object.fromEntries(
  performanceEntries.map(([slug, performance]) => [
    slug,
    {
      deposited: performance?.depositedUsdc ?? 0,
      profitUsdc: performance?.profitUsdc ?? null,
      roiPct: performance?.roi ?? null,
    },
  ]),
);

const totalProfitUsdc = sumCreatorProfit(funds, creatorId, profitByFundSlug);
const totalDepositedUsdc = performanceEntries.reduce(
  (sum, [, performance]) => sum + (performance?.depositedUsdc ?? 0),
  0,
);
const totalReturnedUsdc = performanceEntries.reduce((sum, [, performance]) => {
  if (!performance) return sum;
  return (
    sum +
    (performance.aumUsdc ??
      performance.depositedUsdc + performance.profitUsdc)
  );
}, 0);
const totalFeesUsdc = performanceEntries.reduce((sum, [slug, performance]) => {
  if (!performance || performance.profitUsdc <= 0) return sum;
  const fund = funds.find((f) => f.slug === slug);
  const share = fund?.managerProfitSharePct ?? 0;
  return sum + performance.profitUsdc * (share / 100);
}, 0);
const overallRoi =
  totalDepositedUsdc > 0
    ? Math.round((totalProfitUsdc / totalDepositedUsdc) * 10000) / 100
    : null;

const memberSinceIso = funds
  .map((fund) => fund.createdAt)
  .filter((iso): iso is string => Boolean(iso))
  .sort()[0];
const memberSince = memberSinceIso
  ? new Intl.DateTimeFormat(undefined, {
      month: "short",
      year: "numeric",
    }).format(new Date(memberSinceIso))
  : null;

const polymarketUrl = profileWalletId
  ? `https://polymarket.com/profile/${profileWalletId}`
  : null;

const metricLabel =
  "text-primary/45 text-base font-medium tracking-wide";
const metricValue =
  "text-primary mt-2 font-mono text-2xl font-semibold tracking-tight tabular-nums sm:text-3xl";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <BackLink />

      <div class="mt-8">
        <div class="flex items-start gap-4">
          {
            profileWalletId ? (
              <CreatorAvatar
                client:idle
                address={profileWalletId}
                name={name}
                initialImage={profileImage}
                size="md"
              />
            ) : profileImage ? (
              <img
                src={profileImage}
                alt=""
                width={64}
                height={64}
                class="size-16 shrink-0 rounded-full object-cover"
              />
            ) : (
              <div
                class="bg-primary/10 text-primary flex size-16 shrink-0 items-center justify-center rounded-full text-xl font-semibold"
                aria-hidden="true"
              >
                {initial}
              </div>
            )
          }
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
              <h1 class="text-primary text-2xl font-semibold tracking-tight sm:text-3xl">
                {
                  profileWalletId ? (
                    <CreatorName
                      client:idle
                      address={profileWalletId}
                      fallback={name}
                    />
                  ) : (
                    name
                  )
                }
              </h1>
              {verified && <SealCheck size="base" class="text-[#288cbc]" />}
            </div>

            <div class="mt-2 flex flex-wrap items-center gap-2">
              {
                profileWalletId && (
                  <CreatorWalletChip client:idle address={profileWalletId} />
                )
              }
            </div>

            {
              memberSince && (
                <p class="text-primary/50 mt-2 text-base">
                  Member since {memberSince}
                </p>
              )
            }
          </div>
        </div>

        {
          profileWalletId && (
            <CreatorLocalBio client:idle address={profileWalletId} />
          )
        }

        {
          polymarketUrl && (
            <p class="mt-3">
              <a
                href={polymarketUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary/60 hover:text-primary text-base transition-colors"
              >
                Polymarket profile
              </a>
            </p>
          )
        }
      </div>

      <div
        class="mt-10 grid items-stretch gap-8 lg:grid-cols-[minmax(0,672px)_minmax(0,1fr)]"
      >
        <div class="min-w-0">
          <CreatorFundList
            client:idle
            funds={funds}
            initialPoolTotals={initialPoolTotals}
          />
        </div>

        <aside class="border-primary/10 bg-primary/5 grid h-full min-w-0 grid-cols-2 grid-rows-2 overflow-hidden rounded-lg border">
          <div class="border-primary/10 flex min-w-0 flex-col justify-center border-r border-b p-5 sm:p-6">
            <p class={metricLabel}>Total Deposits</p>
            <p class={metricValue}>{formatUsd(totalDepositedUsdc)}</p>
          </div>
          <div class="border-primary/10 flex min-w-0 flex-col justify-center border-b p-5 sm:p-6">
            <p class={metricLabel}>Total Returned</p>
            <p class={metricValue}>{formatUsd(totalReturnedUsdc)}</p>
          </div>
          <div class="border-primary/10 flex min-w-0 flex-col justify-center border-r p-5 sm:p-6">
            <p class={metricLabel}>Overall Performance</p>
            <p class="mt-2 font-mono text-2xl font-semibold tracking-tight tabular-nums sm:text-3xl">
              {
                overallRoi == null ? (
                  <span class="text-primary/45">—</span>
                ) : (
                  <span
                    class={overallRoi >= 0 ? "text-profit" : "text-red-500"}
                  >
                    {formatPercent(overallRoi)}
                  </span>
                )
              }
            </p>
          </div>
          <div class="flex min-w-0 flex-col justify-center p-5 sm:p-6">
            <p class={metricLabel}>Fees Earned</p>
            <p class={metricValue}>{formatUsd(totalFeesUsdc)}</p>
          </div>
        </aside>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
