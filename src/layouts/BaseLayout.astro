---
// Foundations
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
// Components
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/Navigation.astro";
import AppProviders from "@/components/app/AppProviders";

const {
  pageTitle = "45 Degrees",
  description = "Copy-trade Polymarket managers through pooled funds.",
} = Astro.props;
---
<html
  lang="en"
  class="scroll-smooth"
>
  <head>
    <BaseHead title={pageTitle} description={description} />
    <script is:inline>
      try {
        const raw = localStorage.getItem("carriera:wallet-session");
        if (raw) document.documentElement.dataset.walletSession = "1";
      } catch {}
    </script>
    <style is:inline>
      /* Pre-hydration wallet slot: default shows the "Log in" button; flip to
         the placeholder pill when a saved session is detected. React's portal
         replaces whichever is visible on mount. */
      [data-wallet-slot] [data-slot-when] { display: none; }
      [data-wallet-slot] [data-slot-when="anonymous"] { display: inline-flex; }
      html[data-wallet-session="1"] [data-wallet-slot] [data-slot-when="anonymous"] { display: none; }
      html[data-wallet-session="1"] [data-wallet-slot] [data-slot-when="connected"] { display: inline-flex; }
    </style>
    <script is:inline>
      // Reformat every [data-iso] element into the visitor's local timezone.
      function formatLocalTimes(root = document) {
        root.querySelectorAll("time[data-iso]").forEach((node) => {
          const iso = node.getAttribute("data-iso");
          const format = node.getAttribute("data-format") || "datetime";
          if (!iso) return;
          const opts =
            format === "date"
              ? { dateStyle: "medium" }
              : format === "time"
                ? { timeStyle: "short" }
                : { dateStyle: "medium", timeStyle: "short" };
          try {
            node.textContent = new Date(iso).toLocaleString(undefined, opts);
          } catch {}
        });
      }
      function setupLocalTimes() {
        formatLocalTimes();
        document.addEventListener("astro:after-swap", () => formatLocalTimes());
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupLocalTimes);
      } else {
        setupLocalTimes();
      }
    </script>
  </head>
  <body class="flex flex-col bg-secondary  min-h-svh">
    <AppProviders client:idle />
    <Navigation />
    <main class="grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
