---
// Assets
import Logo from "@/components/assets/Logo.astro";
// fundations
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import MobileNav from "@/components/global/MobileNav.astro";
import { PUBLIC_PRIVY_APP_ID } from "astro:env/client";

const privyConfigured = Boolean(PUBLIC_PRIVY_APP_ID?.trim());

const navLinks = [
  { href: "/", label: "Funds" },
  { href: "/leaderboard", label: "Leaderboard" },
  { href: "/docs/overview", label: "Docs" },
  { href: "https://t.me/+Q0aItbvNIGM5MzVh", label: "Community" },
];

// Placeholder pill shown before React hydrates the wallet button. Mirrors the
// connected WalletAccountMenu shape so connected users don't see a "Log in" flash.
const placeholderClass =
  "bg-accent/40 text-secondary/60 inline-flex min-h-9 min-w-[5.5rem] animate-pulse items-center justify-center rounded-[var(--privy-border-radius-md,0.5rem)] px-2 py-2 text-sm font-medium";
const loginButtonClass =
  "bg-accent text-secondary hover:opacity-90 rounded-full px-4 py-1.5 text-sm font-medium transition-opacity";
---
<section>
  <Wrapper variant="standard">
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 py-5">
      <a href="/" class="flex items-center gap-2">
        <Logo />
      </a>
      <div
        class="hidden items-center justify-center gap-4 text-primary lg:col-span-3 lg:flex"
      >
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="hover:text-primary text-sm duration-300"
              target={link.href.startsWith("http") ? "_blank" : undefined}
              rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </div>
      <div class="col-span-1 flex items-center justify-end gap-3">
        <div class="hidden lg:block">
          {
            privyConfigured ? (
              <div
                id="nav-login-slot"
                data-wallet-slot
                class="flex min-h-9 min-w-[5.5rem] items-center justify-end"
              >
                {/* Pre-hydration placeholders. The swap script in BaseLayout
                    toggles [data-wallet-slot-has-session] based on the
                    wallet-session dataset flag set before React loads. React's
                    portal replaces whichever is visible on mount. */}
                <span
                  data-slot-when="connected"
                  class={placeholderClass}
                  aria-busy="true"
                >
                  Loading…
                </span>
                <button
                  type="button"
                  data-slot-when="anonymous"
                  class={loginButtonClass}
                >
                  Log in
                </button>
              </div>
            ) : (
              <span class="text-primary/60 text-xs">
                Login unavailable
              </span>
            )
          }
        </div>
        <button
          id="navToggle"
          class="hover:text-primary/40 duration-300 text-secondary text-sm lg:hidden"
          aria-expanded="false"
          aria-controls="mobileMenu"
        >
          Menu
        </button>
      </div>
    </div>
  </Wrapper>
</section>
<MobileNav links={navLinks} />
