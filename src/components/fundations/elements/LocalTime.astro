---
/**
 * Renders an ISO timestamp as a <time> element and reformats it in the
 * visitor's timezone on the client via the global [data-iso] hydration script
 * mounted in BaseLayout. The SSR fallback uses the host tz (UTC by default).
 */
interface Props {
  iso: string;
  format?: "datetime" | "date" | "time";
  class?: string;
}

const { iso, format = "datetime", class: className = "" } = Astro.props;

const fallbackFormatter = new Intl.DateTimeFormat("en-US", {
  dateStyle: format === "time" ? undefined : "medium",
  timeStyle: format === "date" ? undefined : "short",
  timeZone: "UTC",
});

const fallback = fallbackFormatter.format(new Date(iso));
---

<time data-iso={iso} data-format={format} class={className}>{fallback}</time>
