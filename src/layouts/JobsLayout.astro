---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import JobEntry from "@/components/jobs/JobEntry.astro"; 
// Content
import { getEntry, getCollection } from "astro:content";
const { frontmatter } = Astro.props;
// Get full company data
const company = await getEntry("companies", frontmatter.company);
// Get related jobs by category
const allJobs = await getCollection("jobs");
const relatedJobs = allJobs
.filter(
(job) =>
job.data.category === frontmatter.category &&
job.slug !== Astro.url.pathname.split("/").pop()
)
.slice(0, 4); 
---
<BaseLayout pageTitle={frontmatter.title}>
   <section>
      <Wrapper variant="standard" class="py-24 ">
      <Text tag="h1"
            variant="display3XL"
            class="font-semibold tracking-tighter text-balance text-primary">
            {frontmatter.title}
      </Text>
       <div  class="items-start mt-12 grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4">
         <div class="lg:sticky lg:top-24 lg:z-50">
            {company && (
                       
                       <div class="flex items-baseline justify-between">
                         <Text tag="h3" variant="textSM" class="font-medium text-primary">
                            Company
                         </Text>
                         <span class="flex-1 mx-2 border-b border-dotted border-primary/30"></span>
                         <a href={`/companies/${company.slug}`} class=" text-primary hover:underline duration-300">
                           {company.data.name}
                         </a>
                      </div>
                       <div class="flex items-baseline justify-between">
                         <Text tag="h3" variant="textSM" class="font-medium text-primary">
                            Location
                         </Text>
                         <span class="flex-1 mx-2 border-b border-dotted border-primary/30"></span>
                         <Text tag="p" variant="textSM" class="text-primary/60  ">
                           {frontmatter.location}
                         </Text>
                      </div>
            )}
            {!frontmatter.isClosed && (
               <div >
                   {company && (
                   <div>
                      <div class="flex items-baseline justify-between">
                         <Text tag="h3" variant="textSM" class="font-medium text-primary">
                            Job Type
                         </Text>
                         <span class="flex-1 mx-2 border-b border-dotted border-primary/30"></span>
                         <Text tag="p" variant="textSM" class="text-primary/60  ">
                            {frontmatter.jobType}
                         </Text>
                      </div>
                      <div class="flex items-baseline justify-between">
                         <Text tag="h3" variant="textSM" class="font-medium text-primary">
                            Type
                         </Text>
                         <span class="flex-1 mx-2 border-b border-dotted border-primary/30"></span>
                         <Text tag="p" variant="textSM" class="text-primary/60  ">
                            {frontmatter.type}
                         </Text>
                      </div>
                      <div class="flex items-baseline justify-between">
                         <Text tag="h3" variant="textSM" class="font-medium text-primary ">
                            Posted on
                         </Text>
                         <span class="flex-1 mx-2 border-b border-dotted border-primary/30"></span>
                         <Text tag="p" variant="textSM" class="text-primary/60  ">
                            <time
                            datetime={new Date(frontmatter.datePosted).toLocaleDateString(
                            "en-US",
                            {
                            year: "numeric",
                            month: "long",
                            day: "2-digit",
                            }
                            )}
                            >
                            {new Date(frontmatter.datePosted).toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "long",
                            day: "2-digit",
                            })}
                            </time>
                         </Text>
                      </div>
                      <div class="flex items-baseline justify-between">
                         <Text tag="h3" variant="textSM" class="font-medium text-primary ">
                            Closes on
                         </Text>
                         <span class="flex-1 mx-2 border-b border-dotted border-primary/30"></span>
                         <Text tag="p" variant="textSM" class="text-primary/60  ">
                            {frontmatter.deadline && (
                            <time datetime={new Date(frontmatter.deadline).toISOString()}>
                            {new Date(frontmatter.deadline).toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "long",
                            day: "2-digit",
                            })}
                            </time>
                            )}
                         </Text>
                      </div>
                   </div>
                   )}
               </div>
             )}
            <div class="flex mt-2">
               <Button isLink size="xs" variant="accent" href="/submit-candidate">
                   Apply
              </Button>
             </div>
         </div>
         {
         frontmatter.isClosed && (
         <div class="lg:col-span-2">
            <Text
               tag="h3"
               variant="text-base"
               class="font-medium text-primary">
                  Oops, you were late. This job offer is closed. 
              </Text>
               <Text tag="p" variant="textSM" class="mt-1  text-primary/60  md:text-balance">
                  You can submit your profile to be notified when new opportunities
                  arise from {company?.data.name}.
               </Text>
               <div class="flex mt-2">
                  <Button isLink size="xs" variant="default" class="w-auto" href="/submit-candidate" >
                  Submit</Button>
               </div>
         </div>
         )
         }
               {!frontmatter.isClosed && 
               <Wrapper variant="prose" class="lg:col-span-2">
                  {company && (
                  <h2 >About {company.data.name}</h2>
                  <p >{company.data.description}</p>
                  )}
                  <slot />
               </Wrapper>
               }
            
            <div class="lg:sticky lg:top-24 lg:z-50">
               {
               relatedJobs.length > 0 && (
               <Text tag="h2" variant="textBase" class="font-medium text-primary">
                     Related Jobs
               </Text>
               <div class="flex flex-col mt-1 divide-primary/10 border-primary/10 divide-y border-y">
                  {relatedJobs.map((job) => (
                  <JobEntry post={job} />
                  ))}
               </div>
               )
               }
            </div>
      </div>
   </section>
</BaseLayout>
