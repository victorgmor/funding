# Polymarket Builder — https://polymarket.com/settings?tab=builder
# API key trio authenticates relayer requests (server-only).
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_PASSPHRASE=

# bytes32 builder code on your profile — attached to orders for fee attribution.
# Copy from Builder settings (not the same as the API key).
PUBLIC_POLY_BUILDER_CODE=
