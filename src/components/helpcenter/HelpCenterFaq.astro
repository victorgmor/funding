---
//Assets

// Icons
import ChevronDown from "@/components/fundations/icons/ChevronDown.astro";

// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// FAQ Data Array
const faq = [
  {
    question: "Can I change my job posting plan later?",
    answer:
      "Yes, you can upgrade or downgrade your plan anytime from your dashboard.",
  },
  {
    question: "Do you offer refunds?",
    answer:
      "We offer pro-rated refunds within the first 14 days of any billing cycle.",
  },
  {
    question: "What payment methods do you accept?",
    answer:
      "We accept all major credit cards. Invoicing is available for annual plans.",
  },
  {
    question: "Is there a free trial?",
    answer:
      "We don’t offer a free trial right now, but you can start with the Starter plan risk-free.",
  },
  {
    question: "What’s included in the Pro plan?",
    answer:
      "You get unlimited job posts, featured listings, access to candidate profiles, and priority support.",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-3 lg:gap-24">
      <div>
        <Text
          class="span"
          variant="textXS"
          class="text-primary/60 flex items-center gap-2 font-medium uppercase"
        >
          FAQ
        </Text>
        <Text
          tag="h3"
          variant="displayMD"
          class="text-primary mt-8 lg:text-balance"
        >
          Frequently Asked Questions
        </Text>
        <Text tag="p" variant="textBase" class="text-primary/60 mt-2 text-base">
          Find answers to the most common questions about our services and
          features.
        </Text>
      </div>
      <div class="flex flex-col gap-4 lg:col-span-2" id="faq-accordion">
        {
          faq.map((item, index) => (
            <div class="overflow-hidden">
              <button
                type="button"
                class="text-primary faq-toggle flex w-full items-center justify-between pb-2 text-left font-medium"
                data-index={index}
              >
                <span>{item.question}</span>
                <ChevronDown
                  data-icon
                  class="size-5 transition-transform duration-200"
                />
              </button>
              <div class="faq-content max-h-0 overflow-hidden transition-all duration-300">
                <div class="border-b pt-2 pb-8">
                  <Text tag="p" class="text-primary/60">
                    {item.answer}
                  </Text>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
  <script type="module">
    document.querySelectorAll(".faq-toggle").forEach((btn) => {
      btn.addEventListener("click", () => {
        const content = btn.nextElementSibling;
        const icon = btn.querySelector("[data-icon]");
        const isOpen =
          content.style.maxHeight && content.style.maxHeight !== "0px";
        document
          .querySelectorAll(".faq-content")
          .forEach((el) => (el.style.maxHeight = "0px"));
        document
          .querySelectorAll("[data-icon]")
          .forEach((icon) => (icon.style.transform = "rotate(0deg)"));
        if (!isOpen) {
          content.style.maxHeight = content.scrollHeight + "px";
          icon.style.transform = "rotate(180deg)";
        }
      });
    });
  </script>
</section>
