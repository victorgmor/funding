---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import FundLifecycleStepper from "@/components/funds/FundLifecycleStepper";
import FundPoolOverview from "@/components/funds/FundPoolOverview";
import FundPerformanceCell from "@/components/funds/FundPerformanceCell";
import FundSidebar from "@/components/funds/FundSidebar";
import FundPageGate from "@/components/funds/FundPageGate";
import SealCheck from "@/components/fundations/icons/SealCheck.astro";
import { getFund } from "@/lib/funds/store";
import { isPaidFund } from "@/lib/funds/access";
import { creatorPath } from "@/lib/funds/creator";
import { computeFundPerformance } from "@/lib/funds/performance";
import { resolvePaymentRecipient } from "@/lib/polymarket/payment-recipient";
import { getPlatformFeeWallet } from "@/lib/funds/platform-fee-wallet";

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect("/404");
}

const fund = await getFund(slug);
if (!fund) {
  return Astro.redirect("/404");
}

const performance = await computeFundPerformance(fund);
const paid = isPaidFund(fund);
const paymentRecipient =
  paid && /^0x[a-fA-F0-9]{40}$/i.test(fund.manager.id)
    ? await resolvePaymentRecipient(fund.manager.id)
    : null;
const platformFeeWallet = paid ? getPlatformFeeWallet() : null;
const fundMeta = {
  slug: fund.slug,
  name: fund.name,
  manager: fund.manager,
  status: fund.status,
  unlockPriceUsdc: fund.unlockPriceUsdc,
  createdAt: fund.createdAt,
};
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <a href="/" class="text-primary/60 hover:text-primary text-sm">← All funds</a>

      <div class="mt-6 flex flex-wrap items-start justify-between gap-4">
        <div>
          <div class="flex flex-wrap items-center gap-3">
            <Text tag="h1" variant="displaySM" class="text-primary font-semibold">
              {fund.name}
            </Text>
            {
              fund.status === "closed" && (
                <span class="border-primary/20 text-primary/60 rounded-full border px-2.5 py-0.5 text-[0.65rem] font-medium uppercase">
                  Closed
                </span>
              )
            }
            {
              paid && (
                <span class="border-primary/20 text-primary/60 rounded-full border px-2.5 py-0.5 text-[0.65rem] font-medium uppercase">
                  ${fund.unlockPriceUsdc?.toFixed(2)}
                </span>
              )
            }
          </div>
          <div class="mt-2 flex items-center gap-2">
            <span class="text-primary/50 text-[0.65rem] font-medium uppercase"
              >Creator</span
            >
            <a
              href={creatorPath(fund.manager.id)}
              class="text-primary hover:text-primary/80 text-sm"
            >
              {fund.manager.name}
            </a>
            {
              fund.manager.verified && (
                <SealCheck size="sm" class="text-[#32BCFF]" />
              )
            }
          </div>
          {
            !paid && (
              <p class="text-primary/60 mt-2 max-w-2xl text-sm">{fund.thesis}</p>
            )
          }
        </div>
        {
          !paid && (
            <FundPerformanceCell
              client:load
              fundSlug={fund.slug}
              roi={performance?.roi ?? null}
              since={fund.createdAt}
              variant="header"
            />
          )
        }
      </div>

      <FundLifecycleStepper client:load fund={fund} />

      {
        paid ? (
          <FundPageGate
            client:load
            fund={fundMeta}
            paymentRecipient={paymentRecipient}
            platformFeeWallet={platformFeeWallet}
          />
        ) : (
          <div class="mt-8 grid gap-8 lg:grid-cols-3">
            <div class="lg:col-span-2 space-y-6">
              <FundPoolOverview client:load fund={fund} />
            </div>
            <div>
              <FundSidebar client:load fund={fund} />
            </div>
          </div>
        )
      }
    </Wrapper>
  </section>
</BaseLayout>
