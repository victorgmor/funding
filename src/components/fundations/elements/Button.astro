---
import { walletNavRadius } from "@/lib/walletNavChrome";

const {
  variant,
  size,
  onlyIconSize,
  iconOnly = false,
  gap,
  isLink = false,
  class: className,
  ...rest
} = Astro.props;

/** Match nav wallet chip: dark fill, light label. */
const defaultClass = [
  "bg-[#181709]",
  "text-white/80",
  "focus:ring-[#181709]",
  "hover:text-white",
];
const accentClass = defaultClass;
const mutedClass = [
  "text-primary",
  "bg-primary/10",
  "focus:ring-muted",
  "hover:bg-primary/20",
];

// Size
const sizes = {
  xxs: ["h-7.5", "px-4", "py-2", "text-base"],
  xs: ["h-8", "px-4", "py-3", "text-base"],
  sm: ["h-9", "px-4", "py-3", "text-base"],
  base: ["h-10", "px-5", "py-4", "text-base"],
  md: ["h-11", "px-5", "py-4", "text-base"],
  lg: ["h-12", "px-5", "py-4", "text-lg"],
  xl: ["h-13", "px-5", "py-4", "text-lg"],
};
// Icon size
const iconSizes = {
  xxs: ["size-7.5", "py-2", "text-base"],
  xs: ["size-8", "text-base"],
  sm: ["size-9", "text-base"],
  base: ["size-10", "text-base"],
  md: ["size-11", "text-base"],
  lg: ["size-12", "text-lg"],
  xl: ["size-13", "text-lg"],
};
const gapMap = {
  xs: ["gap-2"],
  sm: ["gap-4"],
  base: ["gap-8"],
  md: ["gap-10"],
  lg: ["gap-12"],
};

const variantClass = {
  default: defaultClass,
  accent: accentClass,
  muted: mutedClass,
  none: [],
};

const baseClass = [
  "flex",
  "items-center",
  "font-medium",
  "justify-center",
  "transition-colors",
  walletNavRadius,
  "focus:ring-2",
  "focus:outline-none",
  "focus:ring-offset-2",
  "focus:ring-offset-base",
];

const additionalClasses = className
  ? className.split(/\s+/).filter(Boolean)
  : [];
const isIconOnly = iconOnly || Boolean(onlyIconSize);
const sizeKey = isIconOnly && onlyIconSize ? onlyIconSize : size;
const sizeClass = isIconOnly
  ? iconSizes[sizeKey] || []
  : sizes[size] || [];
const gapClass = !isIconOnly && gap ? gapMap[gap] || [] : [];
const variantClasses = variantClass[variant] || [];
---

{isLink ? (
  <a
    class:list={[
      ...baseClass,
      ...variantClasses,
      ...sizeClass,
      ...gapClass,
      ...additionalClasses,
    ]}
    {...rest}
  >
    {isIconOnly ? (
      <slot name="icon" />
    ) : (
      <>
        <slot name="left-icon" />
        <slot />
        <slot name="right-icon" />
      </>
    )}
  </a>
) : (
  <button
    class:list={[
      ...baseClass,
      ...variantClasses,
      ...sizeClass,
      ...gapClass,
      ...additionalClasses,
    ]}
    {...rest}
  >
    {isIconOnly ? (
      <slot name="icon" />
    ) : (
      <>
        <slot name="left-icon" />
        <slot />
        <slot name="right-icon" />
      </>
    )}
  </button>
)}
