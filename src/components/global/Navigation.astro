---
// Assets
import Logo from "@/components/assets/Logo.astro";
// fundations
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import MobileNav from "@/components/global/MobileNav.astro";
import { PUBLIC_PRIVY_APP_ID } from "astro:env/client";
import { walletNavButtonClass } from "@/lib/walletNavChrome";

const privyConfigured = Boolean(PUBLIC_PRIVY_APP_ID?.trim());

const navLinks = [
  { href: "/", label: "Funds" },
  { href: "/leaderboard", label: "Leaderboard" },
  { href: "/docs/overview", label: "Docs" },
  { href: "https://t.me/+Q0aItbvNIGM5MzVh", label: "Community" },
];
---
<section>
  <Wrapper variant="standard">
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 py-5">
      <a href="/" class="flex items-center gap-2">
        <Logo />
      </a>
      <div
        class="hidden items-center justify-center gap-4 text-primary lg:col-span-3 lg:flex"
      >
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="hover:text-primary text-sm font-medium duration-300"
              target={link.href.startsWith("http") ? "_blank" : undefined}
              rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </div>
      <div class="col-span-1 flex items-center justify-end gap-3">
        <div class="hidden lg:block">
          {
            privyConfigured ? (
              <div
                id="nav-login-slot"
                data-wallet-slot
                class="flex min-h-9 min-w-[5.5rem] items-center justify-end"
              >
                {/* One chip — label flips Log in ↔ Loading…; React fills profile. */}
                <button
                  type="button"
                  data-wallet-login
                  class={walletNavButtonClass}
                >
                  <span data-wallet-label-anon>Log in</span>
                  <span data-wallet-label-session>Loading…</span>
                </button>
              </div>
            ) : (
              <span class="text-primary/60 text-xs">
                Login unavailable
              </span>
            )
          }
        </div>
        <button
          id="navToggle"
          class="hover:text-primary/40 duration-300 text-secondary text-sm lg:hidden"
          aria-expanded="false"
          aria-controls="mobileMenu"
        >
          Menu
        </button>
      </div>
    </div>
  </Wrapper>
</section>
<MobileNav links={navLinks} />
