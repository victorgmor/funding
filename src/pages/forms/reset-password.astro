---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <Text
        tag="h1"
        variant="display3XL"
        class="font-semibold tracking-tighter capitalize text-primary text-balance"
        >Reset Your Password. <br class="hidden lg:block" /> Rebuild Your Life</Text
      >
      <form
        action="#"
        method="POST"
        class="flex flex-col w-full mt-12 gap-2 lg:w-1/4"
      >
        <div class="flex flex-col gap-1">
          <label for="email" class="block text-sm font-medium text-primary"
            >Email Address</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-0 text-xs bg-transparent border-0 border-b border-primary/10 focus:border-primary text-primary focus:ring-0 focus:outline-none"
          />
        </div>
       

        <div class="flex mt-2">
          <Button type="submit" size="xs" variant="default">
            Get your password, again.
          </Button>
        </div>
      </form>
    </Wrapper>
  </section>
</BaseLayout>
