---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import BackLink from "@/components/fundations/elements/BackLink.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import FundDetailHeader from "@/components/funds/FundDetailHeader";
import FundLifecycleTestPanel from "@/components/funds/FundLifecycleTestPanel";
import FundPoolOverview from "@/components/funds/FundPoolOverview";
import FundSidebar from "@/components/funds/FundSidebar";
import { getFund } from "@/lib/funds/store";
import { computeFundPoolPerformance } from "@/lib/funds/performance";

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect("/404");
}

const fund = await getFund(slug);
if (!fund) {
  return Astro.redirect("/404");
}

const performance = await computeFundPoolPerformance(fund);
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <BackLink />

      <div class="mt-8">
        <FundDetailHeader
          client:load
          fund={fund}
          initialPerformance={performance}
        />

        <div
          class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,360px)] lg:items-start"
        >
          <div class="min-w-0">
            <FundPoolOverview client:load fund={fund} />
            <FundLifecycleTestPanel client:visible fund={fund} />
          </div>

          <aside class="min-w-0">
            <FundSidebar client:load fund={fund} />
          </aside>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
