---
// Assets
import Logo from "@/components/assets/Logo.astro";
import { PUBLIC_PRIVY_APP_ID } from "astro:env/client";

const privyConfigured = Boolean(PUBLIC_PRIVY_APP_ID?.trim());
const { links = [] } = Astro.props;

// Mirrors the connected wallet button shape — see Navigation.astro.
const placeholderClass =
  "bg-accent/40 text-secondary/60 inline-flex min-h-9 min-w-[5.5rem] animate-pulse items-center justify-center rounded-[var(--privy-border-radius-md,0.5rem)] px-2 py-2 text-sm font-medium";
const loginButtonClass =
  "bg-accent text-secondary hover:opacity-90 w-full rounded px-3 py-2 text-sm font-medium";
---
<div id="mobileMenu" class="lg:hidden fixed inset-0 z-40 hidden" aria-hidden="true">
  <div
    class="relative z-10 m-4 rounded-lg outline-2 outline-primary/10 bg-secondary p-4 shadow-2xl"
  >
    <div class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <Logo />
      </a>
      <button
        class="hover:text-primary text-primary duration-300 text-sm"
        data-close-nav
      >
        Close
      </button>
    </div>
    <nav class="mt-12 flex flex-col gap-3 ">
      {links.map((link) => (
        <a
          href={link.href}
          class="hover:text-primary/40 duration-300 text-primary text-sm"
          target={link.href.startsWith("http") ? "_blank" : undefined}
          rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="mt-12 lg:hidden">
      {
        privyConfigured ? (
          <div
            id="mobile-login-slot"
            data-wallet-slot
            class="flex min-h-9 items-center"
          >
            <span
              data-slot-when="connected"
              class={placeholderClass}
              aria-busy="true"
            >
              Loading…
            </span>
            <button
              type="button"
              data-slot-when="anonymous"
              class={loginButtonClass}
            >
              Log in
            </button>
          </div>
        ) : (
          <span class="text-primary/60 text-xs">Login unavailable</span>
        )
      }
    </div>
  </div>
</div>
<script is:inline>
  const navToggle = document.getElementById("navToggle");
  const mobileMenu = document.getElementById("mobileMenu");
  const closeTargets = mobileMenu?.querySelectorAll("[data-close-nav]");
  const openNav = () => {
    mobileMenu.classList.remove("hidden");
    navToggle?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  };
  const closeNav = () => {
    mobileMenu.classList.add("hidden");
    navToggle?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  };
  navToggle?.addEventListener("click", () => {
    const isOpen = navToggle.getAttribute("aria-expanded") === "true";
    if (isOpen) {
      closeNav();
    } else {
      openNav();
    }
  });
  closeTargets?.forEach((btn) => {
    btn.addEventListener("click", closeNav);
  });
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 1024) {
      closeNav();
    }
  });
</script>
