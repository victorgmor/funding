---
import { AstroSeo } from "@lexingtonthemes/seo";

const site = Astro.site?.href?.replace(/\/$/, "") || "https://45degrees.xyz";
const {
  title = "PolyFund",
  description = "Copy-trade Polymarket managers through pooled funds.",
  canonical = Astro.url.href,
  ogImage = `${site}/og.png`,
} = Astro.props;
---

<AstroSeo
  title={title}
  description={description}
  canonical={canonical}
  openGraph={{
    url: canonical,
    title,
    description,
    images: [
      {
        url: ogImage,
        width: 1200,
        height: 630,
        alt: title,
        type: "image/png",
      },
    ],
    site_name: "PolyFund",
    type: "website",
    locale: "en_US",
  }}
  twitter={{
    cardType: "summary_large_image",
  }}
/>
<meta name="robots" content="index, follow" />
