---
// Assets
import { Image } from "astro:assets";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import ShareButtons from "@/components/fundations/elements/ShareButtons.astro";
import BlogEntries from "@/components/blog/BlogEntries.astro";
// Content
const { frontmatter } = Astro.props;
import { getEntry } from "astro:content";
const team = await getEntry("team", frontmatter.team);
// Get all posts and filter by tag
import { getCollection } from "astro:content";
const allPosts = await getCollection("posts");
const relatedPosts = allPosts.filter((post) =>
  post.data.tags.some((tag) => frontmatter.tags.includes(tag))
);
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <Text
        tag="h1"
        variant="display3XL"
        class="text-primary font-semibold tracking-tighter text-balance"
        >{frontmatter.title}</Text
      >
      <div class="mt-12 grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4">
        <div class="lg:sticky lg:top-24 lg:z-40">
          <div class="flex flex-wrap items-center gap-1">
            {
              frontmatter.tags.map((tag) => (
                <a
                  href={`/blog/tags/${tag}`}
                  class="text-primary font-mono text-xs font-medium uppercase duration-300 hover:underline"
                >
                  {tag}
                </a>
              ))
            }
          </div>
          <Text tag="p" variant="textSM" class="text-primary/60 mt-1">
            {frontmatter.description}
          </Text>
          <div class="mt-4">
            {
              team && (
                <a
                  href={`/team/${team.slug}`}
                  class="flex items-center gap-3 transition hover:opacity-80"
                >
                  {team?.data?.image?.url && (
                    <Image
                      width={100}
                      height={100}
                      src={team.data.image.url}
                      alt={team.data.image.alt}
                      class="inline-block size-9 rounded-full object-cover object-center"
                    />
                  )}
                  <Text tag="p" variant="textXS" class="text-primary/60">
                    <span class="">
                      Written in
                      <span class="text-primary/60 font-medium">
                        <time
                          datetime={new Date(frontmatter.pubDate).toISOString()}
                        >
                          {new Date(frontmatter.pubDate).toLocaleDateString(
                            "en-US",
                            {
                              year: "numeric",
                              month: "long",
                              day: "2-digit",
                            }
                          )}
                        </time>
                      </span>
                    </span>
                    <span class="">
                      by
                      <span class="text-primary/60 font-medium">
                        {team.data.name}
                      </span>
                    </span>
                    <span class="block"> {team.data.role}</span>
                  </Text>
                </a>
              )
            }
          </div>
          <Text
            tag="p"
            variant="textSM"
            class="text-primary/60 mt-8 mb-2 font-medium"
          >
            Share this article:
          </Text>
          <ShareButtons description={frontmatter.description} />
        </div>
        <div class="lg:col-span-2">
          <Image
            width={600}
            height={600}
            alt={frontmatter.image.alt}
            src={frontmatter.image.url}
            class="size-full max-h-50 rounded object-cover object-center lg:col-span-2"
          />
          <Wrapper variant="prose" class="mt-2">
            <slot />
          </Wrapper>
        </div>
        {
          relatedPosts.length > 0 && (
            <div>
              <Text
                tag="h2"
                variant="textBase"
                class="text-primary font-medium"
              >
                Related posts
              </Text>
              <div class="divide-primary/10 border-primary/10 mt-1 flex flex-col divide-y border-y">
                {relatedPosts.slice(0, 3).map((post) => (
                  <BlogEntries post={post} />
                ))}
              </div>
            </div>
          )
        }
      </div>
    </Wrapper>
  </section>
</BaseLayout>
