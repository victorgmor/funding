---
import { featured } from "../../data/featured.json";
---

<section>
  <div
    class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
    <div class="border-t border-zinc-800 pt-2">
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-0">
        <p class="text-white text-base tracking-wide font-display uppercase">
          Featured positions
        </p>
        <div>
          <p class="text-base tracking-tight text-white">
            Discover a wide range of thrilling job opportunities that align with
            your interests and chosen field of study.
          </p>
          <p class="mt-32">
            <a
              href="/board/all-categories"
              class="text-white text-xs tracking-wide hover:text-zinc-500 uppercase font-display"
              >See all categories</a
            >
          </p>
        </div>
        <ul
          class="flex flex-col mt-12 col-span-full divide-y border-y divide-zinc-800 border-zinc-800"
          role="list">
          {
            featured.slice(0, 10).map((template) => (
              <>
                <li class="w-full py-2">
                  <a
                    href={template.url}
                    title={template.title}
                    class="grid grid-cols-1 md:grid-cols-2 gap-2 lg:gap-0 w-full lg:grid-cols-3 text-white hover:text-zinc-500 duration-200">
                    <div>
                      <div class="flex-shrink-0 block">
                        <div class="flex items-center">
                          <div class=" font-display  tracking-wide">
                            <p class="text-base  tracking-wide">
                              {template.title}
                            </p>
                            <div class="inline-flex items-center gap-2 mt-1 w-full text-xs ">
                              <span>{template.company}</span>一
                              <span>{template.place}</span>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div>
                      <p class=" text-base  line-clamp-2">
                        {template.description}
                      </p>
                    </div>
                    <div class="lg:ml-auto">
                      <div class="inline-flex items-center  justify-between w-full">
                        <div class="inline-flex items-center gap-2 text-xs ">
                          <span>{template.time} ago</span>
                          <span> &bull;</span>
                          <span>{template.applicants} Applicants</span>
                        </div>
                      </div>
                    </div>
                  </a>
                </li>
              </>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
