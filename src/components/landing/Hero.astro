---
import Text from "@/components/fundations/elements/Text.astro";
import { walletNavButtonClass } from "@/lib/walletNavChrome";
---

<div>
  <Text
    tag="h1"
    variant="display3XL"
    class="text-primary font-semibold tracking-tighter text-balance"
  >
    Get funding.<br />Back the best edge.
  </Text>
  <p class="text-primary/60 mt-4 max-w-2xl text-base">
    Creators run discretionary pools. Investors commit capital from their deposit
    wallets; managers trade with proportional fan-out. Non-custodial on Polygon.
  </p>
  <div class="mt-6">
    <a href="/funds/create" class={walletNavButtonClass}>
      Create fund
    </a>
  </div>
</div>
