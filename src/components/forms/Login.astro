<section>
  <div
    class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
    <div class="border-t border-zinc-800 pt-2">
      <div class="flex flex-col gap-8 lg:gap-0">
        <p class="text-white text-base tracking-wide font-display uppercase">
          Log in
        </p>
        <p
          class="text-base uppercase md:text-3xl mt-32 lg:text-6xl font-display tracking-tight text-white">
          Welcome Back! Let's Get Started
        </p>
        <div class="mt-12 col-span-full">
          <div class="flex flex-col gap-4">
            <div class="flex flex-col md:flex-row gap-4">
              <button
                class="text-white uppercase font-display tracking-wide text-xs"
                type="button"
                >Log in with google
              </button>
              <span class="text-white font-display">|</span>
              <button
                class="text-white uppercase font-display tracking-wide text-xs"
                type="button"
                >Log in with X
              </button>
              <span class="text-white font-display">|</span>
              <button
                class="text-white uppercase font-display tracking-wide text-xs"
                type="button"
                >Log in with linkedin
              </button>
            </div>

            <div class="border-t border-zinc-800 pt-2">
              <p
                class="text-xs text-white uppercase font-display tracking-wide bg-black">
                Or continue with
              </p>
            </div>
          </div>
          <form action="#" class="pt-2">
            <div
              class="flex flex-col divide-y divide-zinc-800 w-full border-t border-zinc-800">
              <div>
                <label name="name" class="sr-only"> First name</label>
                <input
                  type="text"
                  placeholder="Your name"
                  class="bg-transparent placeholder-white block w-full h-10 text-xs border-0 pl-0 pr-10 text-white focus:ring-0 focus:border-b focus:border-white focus:ring-white"
                />
              </div><div class="col-span-full">
                <label class="sr-only" name="company">Password</label>
                <input
                  class="bg-transparent placeholder-white block w-full h-10 text-xs border-0 pl-0 pr-10 text-white focus:ring-0 focus:border-b focus:border-white focus:ring-white"
