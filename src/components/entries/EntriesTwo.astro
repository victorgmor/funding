---
const { title, url, description, pubDate, author, image } = Astro.props;
---

<li>
  <a href={url} title={title}>
    <article
      class="grid grid-cols-1 md:grid-cols-4 gap-2 border-t border-zinc-800 py-2 lg:gap-4">
      <div class="w-full">
        <img
          class="border border-zinc-800 lg:object-cover bg-center lg:h-full w-full h-64"
          src={image}
          alt={title}
        />
      </div>
      <div
        class="flex flex-col items-start md:col-span-3 justify-between flex-1 w-full mt-4 text-white font-display tracking-wide">
        <div class="w-full">
          <div>
            <p class="font-medium uppercase font-display">{title}</p>
          </div>
          <p
            class="text-base uppercase md:text-3xl mt-12 lg:mt-32 lg:text-6xl font-display tracking-tight text-white line-clamp-2">
            {description}
          </p>
        </div>
        <footer>
          <div class="inline-flex space-x-1 items-center mt-6">
            <p class="text-xs font-medium">
              {author}
            </p>
            <span aria-hidden="true">&middot;</span>
            <div class="flex text-xs">
              <time datetime="2020-03-16"> {pubDate}</time>
            </div>
          </div>
        </footer>
      </div>
    </article>
  </a>
</li>
