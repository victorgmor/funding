---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout>
  <section>
    <div
      class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
      <div class="border-t border-stone-700 pt-2">
        <div class="flex flex-col gap-8 lg:gap-0">
          <p
            class="text-base font-medium text-white uppercase font-display">
            Error 404
          </p>
          <p
            class="text-base md:text-3xl mt-32 lg:text-6xl font-display uppercase text-white text-balance">
            Oops! The page you're looking for couldn't be found. It may have
            been moved, deleted, or doesn't exist. Please check the URL for
            typos or return to the homepage to start fresh
          </p>
          <p class="mt-32">
            <a
              href="/"
              class="hover:text-stone-400 text-base font-medium text-white uppercase font-display"
              >go back gome</a
            >
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
