---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
import CompanyOpenJobs from "@/components/board/CompanyOpenJobs.astro";
import { getCollection } from "astro:content";
const allPosts = await getCollection("companies");
---

<BaseLayout>
  <section>
    <div
      class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
      <div class="border-t border-zinc-300 pt-2">
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-0">
          <p class="text-base font-medium text-black uppercase font-display">
            {frontmatter.company}
          </p>
          <div class="text-base tracking-tight text-black">
            <p class="gap-4 inline-flex items-center">{frontmatter.link}</p>
          </div>
          <div>
            <ul
              role="list"
              class="flex flex-col divide-y divide-zinc-300 border-zinc-300 border-t lg:border-t-0 border-b text-base tracking-tight text-black w-full">
              <li class="inline-flex items-center justify-between w-full pb-2">
                Location <span> {frontmatter.location}</span>
              </li>
              <li class="inline-flex items-center justify-between w-full py-2">
                Employees <span> {frontmatter.employees}</span>
              </li>
              <li class="inline-flex items-center justify-between w-full py-2">
                Link <span
                  ><a href={frontmatter.link}> {frontmatter.link}</a></span
                >
              </li>
            </ul>
          </div>
          <p
            class="text-base uppercase md:text-3xl mt-32 lg:text-6xl font-display tracking-tight text-black col-span-full">
            profile
          </p>
        </div>
      </div>
      <div class="border-t border-zinc-300 pt-2">
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-0">
          <p class="text-base font-medium text-black uppercase font-display">
            Company Profile
          </p>
          <div class="col-span-2 prose-styles">
            <slot />
          </div>
        </div>
      </div>
      <div
        class="border-t border-zinc-300 text-black text-xs uppercase font-display tracking-wide pt-2 mt-32">
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-0">
          <p class="text-base font-medium text-black uppercase font-display">
            {frontmatter.company} open jobs
          </p>
          <div
            class="font-display uppercase tracking-wide text-black text-xs flex flex-col gap-2 col-span-2">
            <a
              href={frontmatter.url}
              title={frontmatter.company}
              aria-label={frontmatter.company}>
              <div
                class="px-4  sm:grid sm:grid-cols-3 lg: sm:gap-4 sm:px-0 items-start gap-y-4 text-base font-medium text-black uppercase font-display">
                <dt>
                  <p class="tracking-wide font-display">
                    {frontmatter.company}
                  </p>
                </dt>
                <dd
                  class="mt-1 flex flex-col sm:col-span-2 sm:mt-0 w-full hover:text-zinc-500 duration-200">
                  <span>{frontmatter.location}</span>
                  <span>{frontmatter.position}</span>
                  <span>{frontmatter.type}</span>
                  <span>
                    {frontmatter.salary}
                  </span>
                </dd>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
