---
import Icon from "phosphor-astro/AppWindowDuotone.astro";
import { iconSizes, type IconSize } from "@/components/fundations/icons/sizes";

const { size, class: className, ...rest } = Astro.props as {
  size?: IconSize;
  class?: string;
};
---

<Icon
  class:list={[size ? iconSizes[size] : iconSizes.sm, className]}
  {...rest}
/>
