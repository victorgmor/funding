---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Hero from "@/components/landing/Hero.astro";
import TopCreatorsCarousel from "@/components/landing/TopCreatorsCarousel";
import FundListPanel from "@/components/funds/FundListPanel";
import {
  getTopCreators,
  TOP_MANAGERS_CAROUSEL_LIMIT,
} from "@/lib/funds/creators";
import { computePoolTotalsBySlug } from "@/lib/funds/performance";
import { getAllFunds } from "@/lib/funds/store";

const funds = await getAllFunds();
const poolTotals = await computePoolTotalsBySlug(funds);
const profitByFundSlug = Object.fromEntries(
  Object.entries(poolTotals).map(([slug, row]) => [slug, row.profitUsdc ?? 0]),
);
const topCreators = getTopCreators(funds, {
  profitByFundSlug,
  limit: TOP_MANAGERS_CAROUSEL_LIMIT,
});
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <Hero />
      {
        topCreators.length > 0 && (
          <div class="mt-10">
            <TopCreatorsCarousel client:visible creators={topCreators} />
          </div>
        )
      }
      <div class="mt-8">
        <FundListPanel client:idle funds={funds} initialPoolTotals={poolTotals} />
      </div>
    </Wrapper>
  </section>
</BaseLayout>
