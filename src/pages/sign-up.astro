---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---
<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <Text
        tag="h1"
        variant="display3XL"
        class="text-primary font-semibold tracking-tighter text-balance capitalize"
        >Looking for prospects? <br class="hidden lg:block" /> Good luck, Chuck.</Text
      >
      <form
        action="#"
        method="POST"
        class="mt-12 flex w-full flex-col gap-2 lg:w-1/4"
      >
        <div>
          <label for="name" class="text-primary block text-sm font-medium"
            >Full Name</label
          >
          <input
            type="text"
            id="name"
            name="name"
            required
            class="border-primary/10 focus:border-primary text-primary w-full border-0 border-b bg-transparent px-0 text-xs focus:ring-0 focus:outline-none"
          />
        </div>
        <div class="flex flex-col gap-1">
          <label for="email" class="text-primary block text-sm font-medium"
            >Email Address</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            class="border-primary/10 focus:border-primary text-primary w-full border-0 border-b bg-transparent px-0 text-xs focus:ring-0 focus:outline-none"
          />
        </div>
        <div class="flex flex-col gap-1">
          <label for="password" class="text-primary block text-sm font-medium"
            >Password</label
          >
          <input
            type="password"
            id="password"
            name="password"
            required
            class="border-primary/10 focus:border-primary text-primary w-full border-0 border-b bg-transparent px-0 text-xs focus:ring-0 focus:outline-none"
          />
        </div>
        <div>
          <label
            for="confirmPassword"
            class="text-primary block text-sm font-medium"
            >Confirm Password</label
          >
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            required
            class="border-primary/10 focus:border-primary text-primary w-full border-0 border-b bg-transparent px-0 text-xs focus:ring-0 focus:outline-none"
          />
        </div>
        <div class="mt-2 flex flex-wrap items-center gap-1 lg:flex-nowrap">
          <Button type="submit" size="xs" variant="default" class="w-full">
            Sign up
          </Button>
          <Button
            size="xs"
            variant="muted"
            href="#_"
            class="w-full"
          >
            Google
          </Button>
          <Button
            size="xs"
            variant="muted"
            href="#_"
            class="w-full"
          >
            Apple
          </Button>
        </div>
      </form>
      <div class="mt-4 flex items-center gap-1">
        <input
          type="checkbox"
          id="agree"
          name="agree"
          required
          class="text-primary border-primary/20 focus:ring-primary focus:ring-none ring-offset-secondary rounded-full"
        />
        <label for="agree" class="text-primary/60 text-xs"
          >I agree to the <a
            href="#_"
            class="text-primary hover:text-blue font-medium"
            >terms and conditions</a
          ></label
        >
      </div>
      <Text tag="p" variant="textXS" class="text-primary/60 mt-4">
        Go an acccount
        <a
          class="text-primary hover:text-blue font-medium"
          href="/sign-in"
        >
          Sign in
        </a>
      </Text>
    </Wrapper>
  </section>
</BaseLayout>
