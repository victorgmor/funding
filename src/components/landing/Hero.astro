---
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
---

<div>
  <Text
    tag="h1"
    variant="display3XL"
    class="text-primary font-semibold tracking-tighter text-balance"
  >
    Get funding.<br />Back the best edge.
  </Text>
  <p class="text-primary/60 mt-4 max-w-2xl text-sm">
    Creators run discretionary pools. Investors commit capital from their deposit
    wallets; managers trade with proportional fan-out. Non-custodial on Polygon.
  </p>
  <div class="mt-6">
    <Button
      isLink
      size="sm"
      variant="accent"
      href="/funds/create"
      class="w-fit"
    >
      Create fund
    </Button>
  </div>
</div>
