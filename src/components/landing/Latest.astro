---
import { getCollection } from "astro:content";
const allJobs = await getCollection("openjobs");
import JobEntries from "../board/JobEntries.astro"
---

<section>
  <div
    class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
    <div class="border-t border-zinc-300 pt-2">
      <div class="flex flex-col gap-8 lg:gap-0">
        <p class="text-base font-medium text-black uppercase font-display">
          Latest jobs
        </p>
        <div>
          <p
            class="text-base uppercase md:text-3xl mt-32 lg:text-6xl font-display tracking-tight text-black">
            Stay updated with the newest job openings for developers, designers,
            and marketers in the tech industry. Find your next career move and
            stay ahead of the curve.
          </p>

        </div>
        <ul
          class="flex flex-col mt-12 col-span-full divide-y border-y divide-zinc-300 border-zinc-300"
          role="list">
          {
            allJobs.map((post) => (
              <JobEntries
                url={"/openjobs/" + post.slug}
                type={post.data.type}
                salary={post.data.salary}
                location={post.data.location}
                company={post.data.company}
                position={post.data.position}
                companyLogo={post.data.companyLogo.url}
                alt={post.data.company}
              />
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

