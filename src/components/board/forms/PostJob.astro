---
const featuresList = [
  "Add job poster details · Capture essential details about the job poster, including their name, contact information, and any specific requirements",
  "Add all details · Include comprehensive information about the job itself, such as the job title, description, requirements or responsibilities",
  "Add company details · Provide in-depth information about the company posting the job, including the company name, industry, location, website, size, culture",
];
---

<section>
  <div
    class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
    <div class="border-t border-stone-700 pt-2">
      <div class="flex flex-col gap-8 lg:gap-0">
        <p class="text-base font-medium text-white uppercase font-display">
          Lets find the next candidate for your company
        </p>
        <h1
          class="text-base md:text-3xl mt-32 lg:text-6xl font-display uppercase text-white text-balance">
          Choose your job type below and fill all the job information. In case
          you are choosing a Paid job, remember you need to buy a paid job
          credit first.
        </h1>
      </div>
    </div>
  </div>
</section>
<section>
  <div
    class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-0 border-t pt-2 border-stone-700">
      <p class="text-base font-medium text-white uppercase font-display">
        Find your next candidate
      </p>
      <div class="lg:col-span-2">
        <p
          class="text-base uppercase md:text-3xl lg:text-6xl font-display tracking-tight text-white">
          Boost your job listing, Gain maximum exposure by posting it as a
          featured opportunity
        </p>
        <ul
          role="list"
          class="text-base font-medium mt-32 space-y-2 text-stone-400 uppercase font-display">
          {featuresList.map((feature) => <li>{feature}</li>)}
        </ul>
      </div>
    </div>
    <form
      class="flex flex-col divide-y divide-stone-700 w-full border-t mt-32 border-stone-700">
      <div>
        <label
          for="first-name"
          class="sr-only"
          >First name</label
        >
        <div>
          <input
            type="text"
            name="first-name"
            id="first-name"
            autocomplete="given-name"
            placeholder="First name"
            aria-label="First name"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="last-name"
          class="sr-only"
          >Last name</label
        >
        <div>
          <input
            type="text"
            name="last-name"
            id="last-name"
            autocomplete="family-name"
            placeholder="Last name"
            aria-label="Last name"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="job-title"
          class="sr-only"
          >Job title</label
        >
        <div>
          <input
            type="text"
            name="job-title"
            id="job-title"
            autocomplete="given-name"
            placeholder="Job title"
            aria-label="Job title"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="job-department"
          class="sr-only"
          >Job department</label
        >
        <div>
          <input
            type="text"
            name="job-department"
            id="job-department"
            autocomplete="given-name"
            placeholder="Job department"
            aria-label="Job department"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="job-type"
          class="sr-only"
          >Job type</label
        >
        <div>
          <input
            type="text"
            name="job-type"
            id="job-type"
            autocomplete="family-name"
            placeholder="Job type"
            aria-label="Job type"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="job-location"
          class="sr-only"
          >Job location</label
        >
        <div>
          <input
            type="text"
            name="job-location"
            id="job-location"
            autocomplete="family-name"
            placeholder="Job location"
            aria-label="Job location"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="job-salary"
          class="sr-only"
          >Job salary</label
        >
        <div>
          <input
            type="text"
            name="job-salary"
            id="job-salary"
            autocomplete="family-name"
            placeholder="Job salary"
            aria-label="Job salary"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="job-description"
          class="sr-only"
          >Description</label
        >
        <div>
          <textarea
            id="job-description"
            name="job-description"
            rows="10"
            placeholder="Job description"
            aria-label="Job description"
            class="bg-transparent placeholder-stone-400 font-medium block w-full text-sm border-0 pl-0 pr-10 text-white focus:ring-0 focus:border-b focus:border-white focus:ring-white"
          ></textarea>
        </div>
      </div>
      <div>
        <label
          for="company-name"
          class="sr-only"
          >Company name</label
        >
        <div>
          <input
            type="text"
            name="company-name"
            id="company-name"
            autocomplete="given-name"
            placeholder="Company name"
            aria-label="Company name"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="company-website"
          class="sr-only"
          >Company website</label
        >
        <div>
          <input
            type="text"
            name="company-website"
            id="company-website"
            autocomplete="given-name"
            placeholder="Company website"
            aria-label="Company website"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="company-industry"
          class="sr-only"
          >Company industry</label
        >
        <div>
          <input
            type="text"
            name="company-industry"
            id="company-industry"
            autocomplete="given-name"
            placeholder="Company industry"
            aria-label="Company industry"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="linkedin"
          class="sr-only"
          >LinkedIn Profile</label
        >
        <div>
          <input
            type="text"
            name="linkedin"
            id="linkedin"
            autocomplete="family-name"
            placeholder="LinkedIn Profile"
            aria-label="LinkedIn Profile"
            class="block placeholder-stone-400 font-medium w-full text-sm bg-transparent border-0 pl-0 pr-10 h-12 text-white focus:ring-0 focus:border-b focus:border-stone-700 focus:ring-white"
          />
        </div>
      </div>
      <div>
        <label
          for="company-description"
          class="sr-only"
          >Company Description</label
        >
        <div>
          <textarea
            id="company-description"
            name="company-description"
            rows="10"
            placeholder="Company Description"
            aria-label="Company Description"
            class="bg-transparent placeholder-stone-400 font-medium block w-full text-sm border-0 pl-0 pr-10 text-white focus:ring-0 focus:border-b focus:border-white focus:ring-white"
          ></textarea>
        </div>
      </div>
      <div class="sm:col-span-full pt-2">
        <label
          for="order"
          class="text-base font-medium text-white uppercase font-display tracking-wide"
          >For those who have purchased a featured job credit, please enter your
          order ID below. If you haven't made a purchase yet, you can visit the
          featured <a
            href="/pricing/featured-job-pricing"
            class="hover:text-white text-stone-400 underline"
            >jobs page to buy one</a
          >.</label
        >
        <div class="mt-12 border-t border-stone-700 py-2">
          <input
            type="text"
            name="order"
            id="order"
            autocomplete="order"
            placeholder="your order ID"
            aria-label="your order ID"
            class="bg-transparent placeholder-stone-400 font-medium block w-full text-sm border-0 pl-0 pr-10 text-white focus:ring-0 focus:border-b focus:border-white focus:ring-white"
          />
        </div>
      </div>
      <div class="pt-4">
        <button
          class="flex items-center ring-2 ring-black font-medium text-sm    w-full h-12 px-4 py-2 uppercase  text-black transition-all bg-white hover:bg-white/5  duration-300 focus:ring-2 hover:text-white focus:ring-black focus:ring-offset-white focus:ring-offset-2 justify-between"
          type="submit">
          Submit
          <span>→</span>
        </button>
      </div>
    </form>
  </div>
</section>
