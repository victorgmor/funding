---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
---

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const headings = document.querySelectorAll(" h2,  h3");
    const tocContainer = document.getElementById("table-of-contents");
    if (tocContainer && headings.length > 0) {
      const tocList = document.createElement("ul");
      tocList.classList.add("space-y-1", "list-disc", "text-white","pl-4");
      headings.forEach((heading) => {
        const listItem = document.createElement("li");
        const link = document.createElement("a");
        link.textContent = heading.textContent;
        link.href = `#${heading.id}`;
        link.classList.add("text-white", "uppercase", "hover:text-zinc-500","duration-200","font-display","tracking-wide","text-xs");
        listItem.appendChild(link);
        tocList.appendChild(listItem);
      });
      tocContainer.appendChild(tocList);
      tocContainer.classList.remove("hidden");
    }
  });
</script>

<BaseLayout>
  <section>
    <div
      class="items-center w-full px-8 md:px-12 py-12 lg:pt-32 mx-auto 2xl:max-w-7xl"
    >
      <div class="border-t border-zinc-800 pt-2">
        <img
          class="border border-zinc-800 w-full h-96"
          src={frontmatter.image.url}
          alt={frontmatter.image.alt}
        />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-0 mt-2">
          <p class="text-white text-base tracking-wide font-display uppercase">
            {frontmatter.title}
          </p>
          <p class="text-white text-base tracking-wide font-display uppercase">
            {frontmatter.pubDate.toString().slice(0, 10)} ⏤ by: {
              frontmatter.author
            }
          </p>
          <p
            class="text-base uppercase md:text-3xl mt-32 lg:text-6xl font-display tracking-tight text-white col-span-full"
          >
            {frontmatter.description}
          </p>
          <ol
            role="list"
            class="flex flex-wrap gap-3 mt-32 font-display uppercase tracking-wide text-white text-xs"
          >
            {
              frontmatter.tags.map((tag) => (
                <li class="inline-flex items-center ">
                  <a
                    class="hover:text-zinc-500 duration-200"
                    href={`/tags/${tag}`}
                  >
                    {tag}
                  </a>
                </li>
              ))
            }
          </ol>
        </div>
        <div
          class="pt-2 mt-32 border-t border-zinc-800 grid grid-cols-1 lg:grid-cols-12"
        >
          <div class="lg:col-span-9">
            <div class="prose-styles">
              <slot />
            </div>
          </div>
          <div class="lg:col-span-3">
            <div
              id="table-of-contents"
              class="hidden lg:block lg:sticky lg:top-20 space-y-12"
            >
            <p class="text-white uppercase font-display">Table of contents</p>
              <!-- Your table of contents content here -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
