---
const { title, url, description, pubDate, author, image } = Astro.props;
---

<a
  href={url}
  title={title}
  class="flex flex-col justify-between bg-gray-900 overflow-hidden rounded-xl aspect-3/2 ring-1 ring-gray-700">
  <img
    src={image}
    alt={title}
    class="object-cover h-full w-full object-center group-hover:opacity-75"
  />
  <div class="flex flex-col justify-end">
    <div class="bg-gray-900 p-4">
      <p class="font-medium text-white text-sm font-display uppercase">
        {title}
      </p>
      <p
        aria-hidden="true"
        class="mt-0.5 text-gray-400 sm:mt-1 line-clamp-1 text-xs">
        {description}
      </p>
    </div>
  </div>
</a>
